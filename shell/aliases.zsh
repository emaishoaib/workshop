# Open zshrc in VS Code
alias czsh='code ~/.zshrc'

# Reload zshrc
alias rzsh='source ~/.zshrc'

# Merge paired invoice PDFs in the current directory
alias mergeinv='merge_invoices.py .'

# GitHub + SSH helper
alias gtools='gtools'

# Fuzzy-pick a cmux workspace and switch to it (see cmux/functions.zsh)
alias gzsh='cmux-goto'
